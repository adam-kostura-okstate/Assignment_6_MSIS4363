    gap: 1rem;
    padding: 2rem 1rem;
}
.page-center img.logo {
    max-width: 320px;
    height: auto;
}
.page-center img.store {
    width: 300px;
    height: auto;
}
</style>

<div class="page-center">
    <img src="~/images/buc-ee's_logo.png" alt="Buccees logo" class="logo" />
    <h1>Buccees is coming to Stillwater!</h1>
    <img src="~/images/buccees_store.jpg" alt="Buccees store" class="store" />
</div>

<p></p>
